---
import type { Translations } from '../i18n/cs';
import ColorPicker from './ColorPicker.astro';
interface Props { t: Translations; }
const { t } = Astro.props;
---

<header class="header">
  <div class="container header-inner">
    <a href={t.lang === 'cs' ? '/' : '/en/'} class="logo" aria-label={t.a11y.logoHome}>web<span>rocks</span></a>

    <nav class="nav-links" id="nav-links" aria-label={t.a11y.mainNav}>
      <a href="#services">{t.nav.services}</a>
      <a href="#projects">{t.nav.projects}</a>
      <a href="#pricing">{t.nav.pricing}</a>
      <a href="#contact">{t.nav.contact}</a>
    </nav>

    <div class="nav-actions">
      <ColorPicker t={t} />
      <button type="button" class="icon-btn cursor-ripple-btn" id="cursor-ripple-btn" aria-label={t.a11y.cursorRipple} aria-pressed="false">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4l7.07 17 2.51-7.39L21 11.07z"/>
        </svg>
      </button>
      <a href={t.nav.langSwitchHref} hreflang={t.lang === 'cs' ? 'en' : 'cs'} class="icon-btn lang-btn" aria-label={t.a11y.langSwitch}>
        {t.nav.langSwitch}
      </a>

      <button type="button" class="icon-btn" id="theme-toggle" aria-label={t.a11y.themeToggle} aria-pressed="false">
        <svg aria-hidden="true" id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg aria-hidden="true" id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <button type="button" class="icon-btn hamburger" id="hamburger" aria-label={t.a11y.mobileMenu} aria-expanded="false" aria-controls="nav-links">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('nav-links');

  function syncIcons() {
    const isDark = document.documentElement.dataset.theme === 'dark';
    toggle?.setAttribute('aria-pressed', isDark ? 'true' : 'false');
  }
  syncIcons();

  toggle?.addEventListener('click', () => {
    const current = document.documentElement.dataset.theme;
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    try { localStorage.setItem('theme', next); } catch (e) {}
    syncIcons();
  });

  const mainContent = document.getElementById('main');
  const footerEl = document.querySelector<HTMLElement>('footer');

  function openNav() {
    hamburger?.setAttribute('aria-expanded', 'true');
    hamburger?.classList.add('open');
    navLinks?.classList.add('open');
    mainContent?.setAttribute('inert', '');
    footerEl?.setAttribute('inert', '');
    const firstLink = navLinks?.querySelector<HTMLAnchorElement>('a');
    firstLink?.focus();
  }

  function closeNav() {
    hamburger?.setAttribute('aria-expanded', 'false');
    hamburger?.classList.remove('open');
    navLinks?.classList.remove('open');
    mainContent?.removeAttribute('inert');
    footerEl?.removeAttribute('inert');
  }

  hamburger?.addEventListener('click', () => {
    if (hamburger.getAttribute('aria-expanded') === 'true') {
      closeNav();
      hamburger.focus();
    } else {
      openNav();
    }
  });

  navLinks?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      closeNav();
      hamburger?.focus();
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && hamburger?.getAttribute('aria-expanded') === 'true') {
      closeNav();
      hamburger.focus();
    }
  });
</script>
